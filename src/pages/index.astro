---
import { Image } from 'astro:assets';
import { LeadForm } from '@/components/forms/LeadForm';
import { OfficeCarousel } from '@/components/home/OfficeCarousel';
import { StatsCounter } from '@/components/home/StatsCounter';
import MapIsland from '@/components/map/MapIsland.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import heroPlaceholder from '@/assets/hero-placeholder.svg';

const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base : `${base}/`;
---

<MainLayout
  title="Недвижимость в Дубае и ОАЭ под ключ | 200+ сделок"
  description="Подбор и сопровождение покупки недвижимости в ОАЭ: инвестиции, объекты у моря, off-plan и resale."
>
  <div
    class="pointer-events-none fixed inset-0 -z-10"
    style={`background:
      radial-gradient(1000px 440px at 10% -10%, color-mix(in srgb, var(--color-primary) 22%, transparent), transparent 62%),
      radial-gradient(860px 420px at 90% -5%, color-mix(in srgb, var(--color-accent) 46%, transparent), transparent 66%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-muted) 55%, transparent), transparent 68%);`}
  >
  </div>

  <section class="hero section-padding">
    <div class="container">
      <div class="hero-photo rounded-[var(--radius-xl)]">
        <div class="hero-content">
          <p
            class="hero-eyebrow inline-flex rounded-full border border-white/30 bg-white/10 px-4 py-2 text-xs font-medium text-white/90 uppercase backdrop-blur"
          >
            Дубай и ОАЭ | Полное сопровождение
          </p>
          <h1
            class="hero-title mt-5 max-w-4xl text-4xl font-semibold text-balance text-white sm:text-5xl lg:text-6xl"
          >
            Недвижимость в Дубае и ОАЭ для жизни, инвестиций и пассивного дохода
          </h1>
          <p class="hero-lead mt-5 max-w-2xl text-base text-white/85 sm:text-lg">
            Сопровождаем клиента от первого запроса до передачи ключей. Работаем с первичным и
            вторичным рынком, инвестиционными лотами и объектами у моря.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a
              href={`${normalizedBase}properties`}
              class="hero-btn-primary inline-flex h-11 items-center justify-center rounded-[var(--radius-md)] px-6 text-sm font-medium transition-all hover:-translate-y-0.5"
            >
              Подобрать объект
            </a>
            <a
              href="#lead-form"
              class="hero-btn-secondary inline-flex h-11 items-center justify-center rounded-[var(--radius-md)] border px-6 text-sm font-medium backdrop-blur transition-colors"
            >
              Запросить звонок
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding border-t">
    <div class="container space-y-8">
      <div class="max-w-3xl space-y-3">
        <p class="section-kicker">Step Dream Real Estate</p>
        <h2 class="section-title text-balance">О нас в цифрах</h2>
        <p class="section-description">
          Честные показатели и опыт работы на рынке недвижимости Дубая и ОАЭ.
        </p>
      </div>
      <StatsCounter client:visible />
    </div>
  </section>

  <section class="section-padding border-t">
    <div class="container space-y-10">
      <div class="max-w-3xl space-y-3">
        <p class="section-kicker">Экспертиза</p>
        <h2 class="section-title text-balance">Наша специализация</h2>
        <p class="section-description">
          Подбираем решения под задачу клиента: инвестиции, жизнь у моря, переезд, капитализация и
          арендный доход.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <article class="card-clean">
          <h3 class="text-lg font-medium">Инвестиционные объекты</h3>
          <p class="mt-2 text-sm text-[var(--color-muted-foreground)]">
            Ликвидные проекты с потенциалом роста и доходности.
          </p>
        </article>
        <article class="card-clean">
          <h3 class="text-lg font-medium">Недвижимость у моря</h3>
          <p class="mt-2 text-sm text-[var(--color-muted-foreground)]">
            Апартаменты и residences в премиальных waterfront-локациях.
          </p>
        </article>
        <article class="card-clean">
          <h3 class="text-lg font-medium">Off-plan и resale</h3>
          <p class="mt-2 text-sm text-[var(--color-muted-foreground)]">
            Первичный и вторичный рынок с проверкой документов и условий.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding border-t">
    <div class="container space-y-10">
      <div class="max-w-3xl space-y-3">
        <p class="section-kicker">Люди и опыт</p>
        <h2 class="section-title text-balance">Команда</h2>
        <p class="section-description">
          Эксперты, которые сопровождают клиента на всех этапах сделки: от подбора объекта до
          передачи ключей и постпродажного сопровождения.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article class="team-card">
          <img
            src={`${normalizedBase}images/team-1.svg`}
            alt="Основатель и ведущий консультант"
            loading="lazy"
            class="team-card-image"
          />
          <div class="team-card-body">
            <p class="team-card-role">Founder & Senior Advisor</p>
            <h3 class="team-card-name">Алексей Магомедов</h3>
            <p class="team-card-text">
              Ведет стратегию клиента, переговоры и финальные условия по сделкам.
            </p>
          </div>
        </article>

        <article class="team-card">
          <img
            src={`${normalizedBase}images/team-2.svg`}
            alt="Инвестиционный консультант"
            loading="lazy"
            class="team-card-image"
          />
          <div class="team-card-body">
            <p class="team-card-role">Investment Consultant</p>
            <h3 class="team-card-name">Мария Иванова</h3>
            <p class="team-card-text">
              Подбирает инвестиционные объекты под доходность, ликвидность и срок окупаемости.
            </p>
          </div>
        </article>

        <article class="team-card">
          <img
            src={`${normalizedBase}images/team-3.svg`}
            alt="Специалист по сделкам"
            loading="lazy"
            class="team-card-image"
          />
          <div class="team-card-body">
            <p class="team-card-role">Transaction Manager</p>
            <h3 class="team-card-name">Даниил Ким</h3>
            <p class="team-card-text">
              Контролирует документы, сроки, оплаты и регистрацию на всех этапах сделки.
            </p>
          </div>
        </article>

        <article class="team-card">
          <img
            src={`${normalizedBase}images/team-4.svg`}
            alt="Клиентский менеджер"
            loading="lazy"
            class="team-card-image"
          />
          <div class="team-card-body">
            <p class="team-card-role">Client Success Manager</p>
            <h3 class="team-card-name">Елена Орлова</h3>
            <p class="team-card-text">
              Сопровождает клиентов после покупки: аренда, сервис и операционные вопросы.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding border-t">
    <div class="container space-y-10">
      <div class="max-w-3xl space-y-3">
        <p class="section-kicker">Пространство и сервис</p>
        <h2 class="section-title text-balance">Наш офис</h2>
        <p class="section-description">
          Показываем пространство, где работаем с клиентами и сопровождаем сделки на каждом этапе.
        </p>
      </div>
      <OfficeCarousel client:visible />
    </div>
  </section>

  <section id="process" class="section-padding border-t">
    <div class="container">
      <div class="process-shell space-y-8">
        <div class="max-w-3xl space-y-3">
          <p class="section-kicker process-kicker">Прозрачный процесс</p>
          <h2 class="section-title text-balance">Как проходит сделка</h2>
          <p class="section-description">
            Сопроводим от подборки подходящих объектов до передачи ключей.
          </p>
        </div>

        <div class="process-timeline-wrap">
          <ol class="process-timeline">
            <li class="timeline-item is-complete">
              <span class="timeline-dot" aria-hidden="true"></span>
              <div class="timeline-card">
                <p class="timeline-step">Шаг 01</p>
                <h3>Подбор объектов</h3>
                <p>Определяем цель, бюджет, сроки и стратегию покупки.</p>
              </div>
            </li>
            <li class="timeline-item is-complete">
              <span class="timeline-dot" aria-hidden="true"></span>
              <div class="timeline-card">
                <p class="timeline-step">Шаг 02</p>
                <h3>Просмотры</h3>
                <p>Организуем офлайн и онлайн-показы в удобном формате.</p>
              </div>
            </li>
            <li class="timeline-item is-complete">
              <span class="timeline-dot" aria-hidden="true"></span>
              <div class="timeline-card">
                <p class="timeline-step">Шаг 03</p>
                <h3>Проверка документов</h3>
                <p>Проверяем статус объекта, условия и юридические детали.</p>
              </div>
            </li>
            <li class="timeline-item is-complete">
              <span class="timeline-dot" aria-hidden="true"></span>
              <div class="timeline-card">
                <p class="timeline-step">Шаг 04</p>
                <h3>Переговоры и условия</h3>
                <p>Согласовываем цену, скидки, рассрочку и финальные условия.</p>
              </div>
            </li>
            <li class="timeline-item is-complete">
              <span class="timeline-dot" aria-hidden="true"></span>
              <div class="timeline-card">
                <p class="timeline-step">Шаг 05</p>
                <h3>Договор / бронирование</h3>
                <p>Оформляем договоренности и фиксируем сделку официально.</p>
              </div>
            </li>
            <li class="timeline-item is-complete">
              <span class="timeline-dot" aria-hidden="true"></span>
              <div class="timeline-card">
                <p class="timeline-step">Шаг 06</p>
                <h3>Сопровождение сделки</h3>
                <p>Контролируем платежи, документы и коммуникацию сторон.</p>
              </div>
            </li>
            <li class="timeline-item is-complete">
              <span class="timeline-dot" aria-hidden="true"></span>
              <div class="timeline-card">
                <p class="timeline-step">Шаг 07</p>
                <h3>Регистрация и передача ключей</h3>
                <p>Завершаем регистрацию права собственности и передачу объекта.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding border-t">
    <div class="container grid gap-8 lg:grid-cols-2">
      <div class="space-y-4">
        <p class="section-kicker">Локации</p>
        <h2 class="section-title text-balance">Ключевые районы</h2>
        <p class="section-description">
          Dubai Marina, Business Bay, Downtown Dubai, JVC, Dubai South, Dubai Islands, Palm Jebel
          Ali, Meydan, MBR City, Sharjah, Ajman и другие перспективные локации.
        </p>
        <p
          class="rounded-[var(--radius-lg)] border bg-[var(--color-card)] p-4 text-sm text-[var(--color-muted-foreground)]"
        >
          Компания работает в рамках требований рынка недвижимости Дубая. Регистрационные данные и
          брокерские номера предоставляются по запросу и проверяются через DLD/RERA.
        </p>
      </div>
      <MapIsland />
    </div>
  </section>

  <section class="section-padding border-t">
    <div class="container">
      <article class="legal-card">
        <div class="max-w-3xl space-y-3">
          <p class="section-kicker">Юридическая информация</p>
          <h2 class="section-title text-balance">Проверка регистрации и прозрачность</h2>
          <p class="section-description">
            В Дубае брокерские компании и брокеров можно проверять через официальный реестр Dubai
            Land Department / RERA, а также через Dubai REST.
          </p>
        </div>
        <div class="legal-points">
          <p>Работаем в соответствии с требованиями рынка недвижимости Дубая и ОАЭ.</p>
          <p>
            Регистрационные данные, лицензии и брокерские номера предоставляем клиенту по запросу.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section id="lead-form" class="section-padding border-t">
    <div class="container grid gap-6 lg:grid-cols-2">
      <div class="space-y-4 rounded-[var(--radius-lg)] border bg-[var(--color-card)] p-6">
        <p class="section-kicker">Быстрый старт</p>
        <h2 class="section-title text-balance">Получите персональную подборку объектов</h2>
        <p class="section-description">
          Поможем определить стратегию, подберем релевантные варианты и дадим прозрачный план
          сделки.
        </p>
        <Image
          src={heroPlaceholder}
          alt="Консультация по недвижимости в ОАЭ"
          widths={[480, 720, 960]}
          sizes="(max-width: 1024px) 100vw, 480px"
          loading="lazy"
          class="rounded-[var(--radius-lg)] border"
        />
      </div>
      <div class="rounded-[var(--radius-lg)] border bg-[var(--color-card)] p-2">
        <LeadForm client:idle />
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    padding-top: 2rem;
  }

  .hero-photo {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 0.18);
    background-image:
      linear-gradient(105deg, rgb(2 6 23 / 0.84), rgb(15 23 42 / 0.6) 45%, rgb(15 23 42 / 0.42)),
      radial-gradient(circle at 80% 20%, rgb(121 66 251 / 0.34), transparent 40%),
      url('images/hero-bg.svg');
    background-size: cover;
    background-position: center;
    box-shadow: var(--shadow-2xl);
  }

  .hero-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgb(2 6 23 / 0.6), transparent 45%),
      repeating-linear-gradient(
        120deg,
        rgb(255 255 255 / 0.06) 0,
        rgb(255 255 255 / 0.06) 1px,
        transparent 1px,
        transparent 14px
      );
    mix-blend-mode: soft-light;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 3.25rem 2rem;
    animation: hero-fade 700ms ease-out both;
  }

  .hero-eyebrow {
    letter-spacing: 0.14em;
    font-weight: 600;
  }

  .hero-title {
    line-height: 1.06;
    letter-spacing: -0.02em;
    text-wrap: balance;
    text-shadow: 0 10px 30px rgb(0 0 0 / 0.32);
  }

  .hero-lead {
    line-height: 1.72;
    max-width: 62ch;
    text-wrap: pretty;
  }

  .section-kicker {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-primary) 72%, var(--color-muted-foreground));
  }

  .section-title {
    font-size: clamp(1.95rem, 2.5vw, 2.7rem);
    line-height: 1.14;
    letter-spacing: -0.018em;
    font-weight: 650;
  }

  .section-description {
    font-size: 1.04rem;
    line-height: 1.72;
    color: color-mix(in srgb, var(--color-muted-foreground) 90%, var(--color-foreground));
    max-width: 66ch;
    text-wrap: pretty;
  }

  .hero-btn-primary {
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    box-shadow: 0 10px 30px rgb(121 66 251 / 0.38);
  }

  .hero-btn-primary:hover {
    filter: brightness(1.05);
  }

  .hero-btn-secondary {
    border-color: rgb(255 255 255 / 0.44);
    background: rgb(255 255 255 / 0.14);
    color: rgb(255 255 255);
  }

  .hero-btn-secondary:hover {
    background: rgb(255 255 255 / 0.24);
  }

  :global(html:not(.dark)) .hero-photo {
    background-image:
      linear-gradient(106deg, rgb(2 6 23 / 0.9), rgb(15 23 42 / 0.72) 44%, rgb(15 23 42 / 0.56)),
      radial-gradient(circle at 78% 18%, rgb(121 66 251 / 0.34), transparent 42%),
      url('images/hero-bg.svg');
  }

  :global(html.dark) .hero-photo {
    background-image:
      linear-gradient(106deg, rgb(2 6 23 / 0.94), rgb(15 23 42 / 0.8) 44%, rgb(15 23 42 / 0.66)),
      radial-gradient(circle at 78% 18%, rgb(140 92 255 / 0.3), transparent 44%),
      url('images/hero-bg.svg');
  }

  @media (min-width: 768px) {
    .hero-content {
      padding: 4.5rem 3.25rem;
    }
  }

  .card-clean {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-primary) 16%, var(--color-border));
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--color-accent) 34%, var(--color-card)) 0%,
      color-mix(in srgb, var(--color-card) 92%, white) 62%
    );
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition:
      transform 260ms ease,
      box-shadow 260ms ease;
  }

  .card-clean h3 {
    font-size: 1.08rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .card-clean p {
    line-height: 1.66;
    text-wrap: pretty;
  }

  .card-clean::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.25rem;
    right: 1.25rem;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--color-primary) 45%, transparent),
      transparent
    );
  }

  .card-clean:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .team-card {
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--color-primary) 16%, var(--color-border));
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 6%, var(--color-card)),
      color-mix(in srgb, var(--color-card) 96%, white)
    );
    transition:
      transform 260ms ease,
      box-shadow 260ms ease;
  }

  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .team-card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center 24%;
    display: block;
  }

  .team-card:nth-child(1) .team-card-image {
    object-position: center 18%;
  }

  .team-card:nth-child(2) .team-card-image {
    object-position: center 14%;
  }

  .team-card:nth-child(3) .team-card-image {
    object-position: center 20%;
  }

  .team-card:nth-child(4) .team-card-image {
    object-position: center 22%;
  }

  .team-card-body {
    padding: 1rem 1rem 1.1rem;
  }

  .team-card-role {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-primary) 76%, var(--color-muted-foreground));
    font-weight: 600;
  }

  .team-card-name {
    margin-top: 0.25rem;
    font-size: 1.06rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 600;
  }

  .team-card-text {
    margin-top: 0.45rem;
    font-size: 0.93rem;
    line-height: 1.55;
    color: var(--color-muted-foreground);
  }

  .legal-card {
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, var(--color-border));
    border-radius: var(--radius-xl);
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--color-accent) 26%, var(--color-card)),
      color-mix(in srgb, var(--color-card) 96%, white)
    );
    padding: 1.35rem;
    display: grid;
    gap: 1rem;
  }

  .legal-points {
    display: grid;
    gap: 0.65rem;
  }

  .legal-points p {
    border: 1px solid color-mix(in srgb, var(--color-primary) 14%, var(--color-border));
    background: color-mix(in srgb, var(--color-card) 94%, white);
    border-radius: calc(var(--radius-lg) - 2px);
    padding: 0.7rem 0.85rem;
    color: var(--color-muted-foreground);
    font-size: 0.93rem;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .legal-card {
      padding: 1.8rem;
      gap: 1.15rem;
    }
  }

  .step-card {
    border: 1px solid var(--color-border);
    background: var(--color-card);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    min-height: 7.5rem;
    display: grid;
    gap: 0.45rem;
  }

  .step-card h3 {
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .step {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .process-shell {
    position: relative;
    padding: 0;
    background: transparent;
  }

  .process-kicker {
    color: color-mix(in srgb, var(--color-primary) 78%, var(--color-muted-foreground));
  }

  .process-timeline-wrap {
