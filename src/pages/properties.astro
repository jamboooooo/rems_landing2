---
import MainLayout from '@/layouts/MainLayout.astro';
import type { PropertyFilters } from '@/entities/property/model/types';
import { PropertiesCatalogIsland } from '@/widgets/properties-grid/PropertiesCatalogIsland';
import PropertiesHero from '@/widgets/properties-hero/PropertiesHero.astro';

function numberParam(value: string | null) {
  if (!value) return undefined;
  const parsed = Number(value);
  return Number.isNaN(parsed) ? undefined : parsed;
}

const params = Astro.url.searchParams;
const initialFilters: PropertyFilters = {
  q: params.get('q') ?? undefined,
  location: params.get('location') ?? undefined,
  status: params.get('status') as PropertyFilters['status'],
  type: params.get('type') as PropertyFilters['type'],
  ownershipType: params.get('ownershipType') as PropertyFilters['ownershipType'],
  source: params.get('source') as PropertyFilters['source'],
  priceFrom: numberParam(params.get('priceFrom')),
  priceTo: numberParam(params.get('priceTo')),
  bedroomsFrom: numberParam(params.get('bedroomsFrom')),
  bedroomsTo: numberParam(params.get('bedroomsTo')),
  bathroomsFrom: numberParam(params.get('bathroomsFrom')),
  bathroomsTo: numberParam(params.get('bathroomsTo')),
  page: numberParam(params.get('page')) ?? 1,
  limit: numberParam(params.get('limit')) ?? 9,
};
---

<MainLayout
  title="Premium Properties Catalog"
  description="Explore curated premium real estate with elegant filtering and image-first browsing."
  pathname={Astro.url.pathname + Astro.url.search}
>
  <section class="relative overflow-hidden pb-8">
    <div
      class="absolute inset-0 -z-10"
      style={`background:
        radial-gradient(1200px 380px at 12% 0%, color-mix(in srgb, var(--color-primary) 18%, transparent), transparent 65%),
        radial-gradient(900px 320px at 86% 0%, color-mix(in srgb, var(--color-accent) 40%, transparent), transparent 62%),
        linear-gradient(180deg, color-mix(in srgb, var(--color-muted) 55%, transparent) 0%, transparent 100%);`}
    >
    </div>
    <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-px bg-[var(--color-border)]">
    </div>
    <PropertiesHero />
    <div class="container">
      <div
        class="grid gap-3 rounded-2xl border bg-[var(--color-card)]/80 p-4 backdrop-blur md:grid-cols-3 md:p-5"
      >
        <div>
          <p class="text-xs tracking-[0.14em] text-[var(--color-muted-foreground)] uppercase">
            curated collection
          </p>
          <p class="mt-1 text-sm font-medium">Premium listings across key locations</p>
        </div>
        <div>
          <p class="text-xs tracking-[0.14em] text-[var(--color-muted-foreground)] uppercase">
            smart filtering
          </p>
          <p class="mt-1 text-sm font-medium">Refine by type, budget, status and more</p>
        </div>
        <div>
          <p class="text-xs tracking-[0.14em] text-[var(--color-muted-foreground)] uppercase">
            image-first view
          </p>
          <p class="mt-1 text-sm font-medium">Clean visual cards with luxury presentation</p>
        </div>
      </div>
    </div>
  </section>
  <PropertiesCatalogIsland client:idle initialFilters={initialFilters} />

  <section class="pb-24">
    <div class="container">
      <div class="rounded-3xl border bg-[var(--color-card)] p-8 md:p-12">
        <p class="text-xs tracking-[0.18em] text-[var(--color-muted-foreground)] uppercase">
          private advisory
        </p>
        <h2 class="mt-3 text-2xl font-semibold md:text-3xl">Need tailored property selection?</h2>
        <p class="mt-3 max-w-2xl text-[var(--color-muted-foreground)]">
          Our advisors can curate an off-market shortlist based on your investment strategy and
          lifestyle requirements.
        </p>
        <a
          href="#"
          class="mt-6 inline-flex items-center rounded-xl border px-5 py-3 text-sm font-medium transition-colors hover:bg-[var(--color-muted)]"
        >
          Contact Private Desk →
        </a>
      </div>
    </div>
  </section>
</MainLayout>
