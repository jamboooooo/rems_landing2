---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type Props = {
  src: ImageMetadata;
  alt: string;
  class?: string;
  widths?: number[];
  sizes?: string;
};

const {
  src,
  alt,
  class: className,
  widths = [480, 768, 1200],
  sizes = '100vw',
} = Astro.props as Props;
---

<Image
  {src}
  {alt}
  widths={widths}
  sizes={sizes}
  loading="lazy"
  decoding="async"
  class={className}
/>
